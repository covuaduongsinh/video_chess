# =============================================================================
# Video Chess (Cờ vua Dương Sinh) — biến môi trường mẫu
# Sao chép file này thành `.env.local` rồi điền giá trị. KHÔNG commit `.env.local`.
# Biến không có tiền tố NEXT_PUBLIC_ chỉ được đọc ở phía server.
# =============================================================================

# --- Supabase (bắt buộc) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Bunny Stream (tuỳ chọn — để trống nếu chưa dùng) ---
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=
NEXT_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_API_KEY=

# --- Cloudflare Stream (tuỳ chọn) ---
NEXT_PUBLIC_CLOUDFLARE_STREAM_SUBDOMAIN=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
